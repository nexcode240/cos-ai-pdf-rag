# Ollama settings
OLLAMA_HOST=http://localhost:11434

# PostgreSQL (required)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cosmos_ai_pdf_rag

# Paths
VECTOR_DB_DIR=data/vectors
PDF_STORAGE_DIR=data/pdfs/uploads

# Models
EMBEDDING_MODEL=nomic-embed-text
DEFAULT_CHAT_MODEL=llama3.2
